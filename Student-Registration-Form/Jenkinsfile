pipeline {
    agent any

    environment {
        PATH = "/Users/mayank/Library/Python/3.9/bin:${env.PATH}"
    }

    options {
        timestamps()
        timeout(time: 15, unit: 'MINUTES')
    }

    stages {

        stage('Checkout') {
            steps {
                echo "── Checking out source code ──"
                checkout scm
            }
        }

        stage('Setup Environment') {
            steps {
                echo "── Installing Python dependencies ──"
                sh '''
                    python3 -m pip install --upgrade pip
                    python3 -m pip install selenium webdriver-manager pytest pytest-html
                '''
            }
        }

        stage('Verify Chrome') {
            steps {
                echo "── Checking Chrome installation ──"
                sh '''
                    CHROME_BIN=$(which google-chrome || which chromium || echo "/Applications/Google Chrome.app/Contents/MacOS/Google Chrome")
                    echo "Chrome path: $CHROME_BIN"
                    "$CHROME_BIN" --version || true
                '''
            }
        }

        stage('Run Tests') {
            steps {
                echo "── Running Selenium test suite ──"
                sh '''
                    mkdir -p reports
                    python3 -m pytest Student-Registration-Form/test_form.py \
                    -v \
                    --html=reports/test_report.html \
                    --self-contained-html \
                    --tb=short \
                    -p no:cacheprovider
                '''
            }
        }
    }

    post {
        always {
            echo "── Publishing test report ──"

            publishHTML(target: [
                reportDir: 'reports',
                reportFiles: 'test_report.html',
                reportName: 'Selenium Test Report',
                keepAll: true,
                allowMissing: true,
                alwaysLinkToLastBuild: true
            ])
        }

        success {
            echo " Build Successful!"
        }

        failure {
            echo " Tests failed — check the report."
        }

        cleanup {
            echo "── Cleaning workspace ──"
            cleanWs()
        }
    }
}
